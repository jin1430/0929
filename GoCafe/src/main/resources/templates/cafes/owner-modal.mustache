{{! cafes/owner-modal.mustache – <dialog> 팝업 }}
{{#isOwner}}
    <dialog id="ownerModal" class="rounded-2xl p-0 w-full max-w-3xl">
        <div class="flex items-center justify-between px-6 py-4 border-b">
            <h3 class="text-xl font-bold">점주 편집</h3>
            <button id="ownerModalClose" class="text-gray-500 hover:text-gray-700 text-2xl leading-none">&times;</button>
        </div>

        <nav class="flex gap-4 px-6 pt-4 border-b">
            <button class="owner-tab tab-active py-3 border-b-2 font-semibold" data-tab="info">카페 정보 수정</button>
            <button class="owner-tab py-3 border-b-2 border-transparent text-gray-500 hover:text-gray-700" data-tab="menu">메뉴 관리</button>
            <button class="owner-tab py-3 border-b-2 border-transparent text-gray-500 hover:text-gray-700" data-tab="delete">카페 삭제</button>
        </nav>

        <div class="p-6 space-y-8">
            <section id="owner-tab-info" class="owner-tab-panel">
                <form id="cafeUpdateForm" method="post" action="/owner/cafes/{{#cafe}}{{id}}{{/cafe}}/update">
                    {{#_csrf}}<input type="hidden" name="{{parameterName}}" value="{{token}}">{{/_csrf}}

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">

                        <label class="block md:col-span-2">
                            <span class="text-sm text-gray-700">카페 이름</span>
                            <input name="name" required maxlength="10" class="mt-1 w-full border rounded-lg px-3 py-2 font-semibold"
                                   value="{{#cafe}}{{name}}{{/cafe}}">
                        </label>
                        <label class="block md:col-span-2">
                            <span class="text-sm text-gray-700">주소</span>
                            <input name="address" required maxlength="60" class="mt-1 w-full border rounded-lg px-3 py-2"
                                   value="{{#cafe}}{{address}}{{/cafe}}">
                        </label>
                        <label class="block">
                            <span class="text-sm text-gray-700">전화번호</span>
                            <input name="phoneNumber" required maxlength="15" class="mt-1 w-full border rounded-lg px-3 py-2"
                                   value="{{#cafe}}{{phoneNumber}}{{/cafe}}">
                        </label>
                        <label class="block">
                            <span class="text-sm text-gray-700">사업자 등록번호</span>
                            <input name="businessCode" required maxlength="10" class="mt-1 w-full border rounded-lg px-3 py-2"
                                   value="{{#cafe}}{{businessCode}}{{/cafe}}">
                        </label>

                        <input type="hidden" name="lat" value="{{#cafe}}{{lat}}{{/cafe}}">
                        <input type="hidden" name="lon" value="{{#cafe}}{{lon}}{{/cafe}}">
                    </div>

                    <div class="mt-6 flex justify-end gap-3">
                        <button type="submit" class="px-5 py-2 rounded-lg bg-green-600 text-white hover:bg-green-700">
                            정보 저장
                        </button>
                    </div>
                </form>
            </section>

            <section id="owner-tab-delete" class="owner-tab-panel hidden">
                <h4 class="text-lg font-bold text-red-600">카페 삭제</h4>
                <p class="mt-2 text-gray-600">
                    카페를 삭제하면 관련된 모든 정보(메뉴, 사진, 리뷰 등)가 영구적으로 삭제되며 복구할 수 없습니다.
                    정말로 삭제하시겠습니까?
                </p>
                <div class="mt-6 flex justify-end">
                    <form method="post" action="/cafes/{{#cafe}}{{id}}{{/cafe}}/delete"
                          onsubmit="return confirm('정말로 카페를 삭제하시겠습니까? 이 작업은 되돌릴 수 없습니다.')">
                        {{#_csrf}}<input type="hidden" name="{{parameterName}}" value="{{token}}">{{/_csrf}}
                        <button type="submit" class="px-5 py-2 rounded-lg bg-red-600 text-white hover:bg-red-700">
                            카페 영구 삭제
                        </button>
                    </form>
                </div>
            </section>

        </div>
    </dialog>
    <style>
        #ownerModal::backdrop { background: rgba(0,0,0,.45); }
    </style>
{{/isOwner}}